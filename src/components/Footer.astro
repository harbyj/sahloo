---
interface Props { lang: 'ar' | 'en' }
const { lang } = Astro.props;
const p    = lang === 'en' ? '/en' : '';
const isAr = lang === 'ar';
---
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href={`${p}/`} class="logo">
          <div class="logo-mark" aria-hidden="true">س</div>
          <span class="logo-text">Sahloo<b>.</b></span>
        </a>
        <p class="footer-brand-desc">
          {isAr ? 'أدوات مجانية بسيطة للحياة اليومية — بدون تسجيل.' : 'Free simple tools for everyday life — no sign-up.'}
        </p>
      </div>

      <div>
        <p class="footer-col-title">{isAr ? 'الأدوات الشائعة' : 'Popular Tools'}</p>
        <ul class="footer-links">
          <li><a href={`${p}/tools/percentage-calculator/`}>{isAr ? 'حاسبة النسبة المئوية' : 'Percentage Calculator'}</a></li>
          <li><a href={`${p}/tools/age-calculator/`}       >{isAr ? 'حساب العمر'           : 'Age Calculator'       }</a></li>
          <li><a href={`${p}/tools/zakat-calculator/`}     >{isAr ? 'حاسبة الزكاة'         : 'Zakat Calculator'     }</a></li>
          <li><a href={`${p}/tools/currency-converter/`}   >{isAr ? 'تحويل العملات'         : 'Currency Converter'   }</a></li>
          <li><a href={`${p}/tools/loan-calculator/`}      >{isAr ? 'حاسبة القروض'          : 'Loan Calculator'      }</a></li>
          <li><a href={`${p}/tools/date-difference/`}      >{isAr ? 'الفرق بين تاريخين'     : 'Date Difference'      }</a></li>
        </ul>
      </div>

      <div>
        <p class="footer-col-title">{isAr ? 'أدوات أخرى' : 'More Tools'}</p>
        <ul class="footer-links">
          <li><a href={`${p}/tools/discount-calculator/`}>{isAr ? 'حاسبة الخصم'       : 'Discount Calculator'}</a></li>
          <li><a href={`${p}/tools/bmi-calculator/`}     >{isAr ? 'مؤشر كتلة الجسم'   : 'BMI Calculator'     }</a></li>
          <li><a href={`${p}/tools/bill-splitter/`}      >{isAr ? 'تقسيم الفاتورة'     : 'Bill Splitter'      }</a></li>
          <li><a href={`${p}/tools/unit-converter/`}     >{isAr ? 'تحويل الوحدات'      : 'Unit Converter'     }</a></li>
          <li><a href={`${p}/tools/gpa-calculator/`}     >{isAr ? 'المعدل التراكمي'     : 'GPA Calculator'     }</a></li>
          <li><a href={`${p}/tools/days-until/`}         >{isAr ? 'كم باقي على'         : 'Days Until'         }</a></li>
        </ul>
      </div>

      <div>
        <p class="footer-col-title">Sahloo</p>
        <ul class="footer-links">
          <li><a href={`${p}/tools/`}  >{isAr ? 'جميع الأدوات'      : 'All Tools'     }</a></li>
          <li><a href={`${p}/privacy/`}>{isAr ? 'سياسة الخصوصية'   : 'Privacy Policy' }</a></li>
          <li><a href={`${p}/contact/`}>{isAr ? 'تواصل معنا'        : 'Contact Us'     }</a></li>
          <li><a href={`${p}/support/`}>{isAr ? 'ادعمنا'            : 'Support Us'     }</a></li>
          <li><a href="#" class="lang-switch">{isAr ? 'English 🌐' : 'عربي 🌐'}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2026 Sahloo سهلو — {isAr ? 'حياتك أسهل مع سهلو 🌿' : 'Simple tools for everyday life 🌿'}</span>
      <div class="footer-bottom-links">
        <a href={`${p}/privacy/`}>{isAr ? 'سياسة الخصوصية' : 'Privacy Policy'}</a>
        <a href={`${p}/contact/`}>{isAr ? 'تواصل معنا'      : 'Contact Us'    }</a>
        <a href={`${p}/support/`}>{isAr ? 'ادعمنا'          : 'Support Us'    }</a>
      </div>
    </div>
  </div>
</footer>
