---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  lang="ar"
  title="جميع الأدوات | Sahloo سهلو"
  description="جميع أدوات وحاسبات سهلو المجانية — حاسبة النسبة المئوية، حساب العمر، تحويل العملات، حاسبة الزكاة، ومزيد من الأدوات المفيدة."
  canonical="https://sahloo.com/tools/"
>
<main id="main">
  <div class="tools-index-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">الرئيسية</a><span class="bc-sep" aria-hidden="true">›</span>
        <span aria-current="page">جميع الأدوات</span>
      </nav>
      <h1 style="margin-top:14px;">جميع <em>الأدوات</em></h1>
      <p>مجانية وبدون تسجيل</p>
    </div>
  </div>
  <div class="container" style="padding-bottom:60px;">
    <div class="cats-row" style="margin-bottom:20px;">
      <button class="cat-chip active" data-cat="all"><span aria-hidden="true">🔢</span> الكل</button>
      <button class="cat-chip" data-cat="money"><span aria-hidden="true">💰</span> المال</button>
      <button class="cat-chip" data-cat="time"><span aria-hidden="true">⏰</span> الوقت</button>
      <button class="cat-chip" data-cat="study"><span aria-hidden="true">📚</span> الدراسة</button>
      <button class="cat-chip" data-cat="health"><span aria-hidden="true">❤️</span> الصحة</button>
      <button class="cat-chip" data-cat="quick"><span aria-hidden="true">⚡</span> سريع</button>
    </div>
    <div class="tools-grid">
      <a href="/tools/percentage-calculator/" class="tool-card" data-name="حاسبة النسبة المئوية" data-kw="احسب النسب المئوية — نسبة من عدد، زيادة، نقصان" data-cat="quick"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">حاسبة النسبة المئوية</div><div class="tool-desc">احسب النسب المئوية — نسبة من عدد، زيادة، نقصان</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/age-calculator/" class="tool-card" data-name="حساب العمر" data-kw="احسب عمرك بالسنوات والأشهر والأيام بدقة" data-cat="time"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">حساب العمر</div><div class="tool-desc">احسب عمرك بالسنوات والأشهر والأيام بدقة</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/zakat-calculator/" class="tool-card" data-name="حاسبة الزكاة" data-kw="احسب زكاة المال والذهب والفضة والأسهم" data-cat="money"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">حاسبة الزكاة</div><div class="tool-desc">احسب زكاة المال والذهب والفضة والأسهم</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/currency-converter/" class="tool-card" data-name="تحويل العملات" data-kw="أسعار صرف لحظية — عملات عربية وعالمية" data-cat="money"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">تحويل العملات</div><div class="tool-desc">أسعار صرف لحظية — عملات عربية وعالمية</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/loan-calculator/" class="tool-card" data-name="حاسبة القروض" data-kw="احسب القسط الشهري والفائدة لأي قرض" data-cat="money"><div class="tool-icon" aria-hidden="true">🏦</div><div class="tool-name">حاسبة القروض</div><div class="tool-desc">احسب القسط الشهري والفائدة لأي قرض</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/date-difference/" class="tool-card" data-name="الفرق بين تاريخين" data-kw="احسب الفرق الدقيق بين أي تاريخين" data-cat="time"><div class="tool-icon" aria-hidden="true">📅</div><div class="tool-name">الفرق بين تاريخين</div><div class="tool-desc">احسب الفرق الدقيق بين أي تاريخين</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/discount-calculator/" class="tool-card" data-name="حاسبة الخصم" data-kw="احسب السعر بعد الخصم ومقدار التوفير" data-cat="money"><div class="tool-icon" aria-hidden="true">🏷️</div><div class="tool-name">حاسبة الخصم</div><div class="tool-desc">احسب السعر بعد الخصم ومقدار التوفير</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/bmi-calculator/" class="tool-card" data-name="مؤشر كتلة الجسم" data-kw="اعرف هل وزنك في النطاق الصحي لطولك" data-cat="health"><div class="tool-icon" aria-hidden="true">⚖️</div><div class="tool-name">مؤشر كتلة الجسم</div><div class="tool-desc">اعرف هل وزنك في النطاق الصحي لطولك</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/bill-splitter/" class="tool-card" data-name="تقسيم الفاتورة" data-kw="وزّع الفاتورة على الأصدقاء مع البقشيش" data-cat="quick"><div class="tool-icon" aria-hidden="true">🧾</div><div class="tool-name">تقسيم الفاتورة</div><div class="tool-desc">وزّع الفاتورة على الأصدقاء مع البقشيش</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/unit-converter/" class="tool-card" data-name="تحويل الوحدات" data-kw="تحويل وحدات الطول والوزن والحرارة والمساحة" data-cat="quick"><div class="tool-icon" aria-hidden="true">📐</div><div class="tool-name">تحويل الوحدات</div><div class="tool-desc">تحويل وحدات الطول والوزن والحرارة والمساحة</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/gpa-calculator/" class="tool-card" data-name="المعدل التراكمي" data-kw="احسب gpa بنظام 4.0 أو 5.0 أو المئوي" data-cat="study"><div class="tool-icon" aria-hidden="true">🎓</div><div class="tool-name">المعدل التراكمي</div><div class="tool-desc">احسب GPA بنظام 4.0 أو 5.0 أو المئوي</div><div class="tool-arrow" aria-hidden="true">←</div></a>
      <a href="/tools/days-until/" class="tool-card" data-name="كم باقي على" data-kw="اعرف كم يوم باقٍ على أي حدث أو مناسبة" data-cat="time"><div class="tool-icon" aria-hidden="true">⏳</div><div class="tool-name">كم باقي على</div><div class="tool-desc">اعرف كم يوم باقٍ على أي حدث أو مناسبة</div><div class="tool-arrow" aria-hidden="true">←</div></a>
    </div>
  </div>
</main>
</Layout>
