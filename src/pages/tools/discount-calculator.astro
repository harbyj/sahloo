---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  lang="ar"
  title="حاسبة الخصم | Sahloo سهلو"
  description="حاسبة الخصم المجانية — احسب السعر بعد التخفيض ومقدار ما وفرته."
  canonical="https://sahloo.com/tools/discount-calculator/"
>
<main id="main" class="tool-page">
  <div class="tool-hero">
    <div class="container--n container">
      <nav class="breadcrumb" aria-label="breadcrumb"><a href="/">الرئيسية</a><span class="bc-sep" aria-hidden="true">›</span><a href="/tools/">الأدوات</a><span class="bc-sep" aria-hidden="true">›</span><span aria-current="page">حاسبة الخصم</span></nav>
<script type="application/ld+json">{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://sahloo.com/"}, {"@type": "ListItem", "position": 2, "name": "الأدوات", "item": "https://sahloo.com/tools/"}, {"@type": "ListItem", "position": 3, "name": "حاسبة الخصم"}]}</script>
      <div class="tool-hero-content">
        <div class="tool-page-icon" aria-hidden="true">🏷️</div>
        <h1 class="tool-page-title">حاسبة الخصم</h1>
        <p class="tool-page-sub">احسب السعر بعد الخصم ومقدار التوفير</p>
      </div>
    </div>
  </div>
  <div class="container--n container" style="padding-top:24px;">
    <div class="calc-card">
      <div class="mode-tabs" role="tablist">
        <button class="mode-tab active" role="tab" onclick="setDM(0,this)">السعر بعد الخصم</button>
        <button class="mode-tab" role="tab" onclick="setDM(1,this)">احسب نسبة الخصم</button>
        <button class="mode-tab" role="tab" onclick="setDM(2,this)">خصومات متعددة</button>
      </div>
      <div id="dm0"><div class="form-row">
        <div class="form-group"><label class="form-label" for="d0a">السعر الأصلي</label><input type="number" inputmode="decimal" class="form-input" id="d0a" placeholder="300"></div>
        <div class="form-group"><label class="form-label" for="d0b">نسبة الخصم (%)</label><input type="number" inputmode="decimal" class="form-input" id="d0b" placeholder="20"></div>
      </div><button class="btn btn-primary btn-full" onclick="calcD(0)">احسب ←</button></div>
      <div id="dm1" hidden><div class="form-row">
        <div class="form-group"><label class="form-label" for="d1a">السعر الأصلي</label><input type="number" inputmode="decimal" class="form-input" id="d1a" placeholder="500"></div>
        <div class="form-group"><label class="form-label" for="d1b">السعر النهائي</label><input type="number" inputmode="decimal" class="form-input" id="d1b" placeholder="350"></div>
      </div><button class="btn btn-primary btn-full" onclick="calcD(1)">احسب ←</button></div>
      <div id="dm2" hidden>
        <div class="form-group"><label class="form-label" for="d2a">السعر الأصلي</label><input type="number" inputmode="decimal" class="form-input" id="d2a" placeholder="1000"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label" for="d2b">الخصم الأول (%)</label><input type="number" inputmode="decimal" class="form-input" id="d2b" placeholder="20"></div>
          <div class="form-group"><label class="form-label" for="d2c">الخصم الثاني (%)</label><input type="number" inputmode="decimal" class="form-input" id="d2c" placeholder="10"></div>
        </div>
        <button class="btn btn-primary btn-full" onclick="calcD(2)">احسب ←</button>
      </div>
      <div class="result-card" id="dRes" aria-live="polite"><div class="result-grid" id="dGrid"></div></div>
    </div>
    <div class="info-section"><div class="info-card"><h2>🏷️ دليل التسوق الذكي</h2>
<p>في مواسم التخفيضات، تلجأ المتاجر للخصومات المتراكمة لإيهامك بصفقة أفضل. استخدم هذه الحاسبة لتعرف السعر الحقيقي قبل الشراء.</p></div>
<div class="info-card"><h2>💡 أنواع الخصومات</h2>
<ul><li><strong>خصم مباشر:</strong> نسبة تُخصم من السعر الأصلي مباشرة</li>
<li><strong>خصومات متراكمة:</strong> مثل "خصم 20% ثم 10% إضافي" — هذا ليس 30%!</li>
<li><strong>اشترِ واحد بنصف سعر الثاني:</strong> فعلياً 25% خصم على كل قطعة</li>
<li><strong>كود خصم:</strong> يُطبق عادةً على السعر بعد الخصم الأصلي</li></ul></div><div class="info-card" itemscope itemtype="https://schema.org/FAQPage"><h2>❓ أسئلة شائعة</h2><div class="faq-list"><div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa0" itemprop="name">ما هو سعر منتج بـ150 ريال بعد خصم 20%؟<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">150 × 0.20 = 30 ريال وفرت. السعر النهائي = 150 − 30 = 120 ريال.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa1" itemprop="name">هل الخصومات المتراكمة تُجمع؟<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa1" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">لا — خصم 20% ثم 10% ≠ 30% خصم. الخصم الثاني يُطبق على السعر المخفَّض. خصم 20%+10% متراكم = 28% فعلياً.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa2" itemprop="name">كيف أجد السعر الأصلي من السعر النهائي؟<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa2" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">إذا كان السعر بعد خصم 20% هو 80 ريال، فالأصلي = 80 ÷ 0.80 = 100 ريال.</span></div></div>
</div></div>
</div>
  </div>
  <section class="related-section container--n container" aria-label="أدوات مشابهة"><div class="section-hd"><h2 class="section-title">أدوات مشابهة</h2><a href="/tools/" class="see-all">جميع الأدوات</a></div><div class="tools-grid"><a href="/tools/percentage-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">حاسبة النسبة المئوية</div><div class="tool-arrow" aria-hidden="true">←</div></a><a href="/tools/age-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">حساب العمر</div><div class="tool-arrow" aria-hidden="true">←</div></a><a href="/tools/zakat-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">حاسبة الزكاة</div><div class="tool-arrow" aria-hidden="true">←</div></a><a href="/tools/currency-converter/" class="tool-card"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">تحويل العملات</div><div class="tool-arrow" aria-hidden="true">←</div></a></div></section>
</main>

<script is:inline>
function setDM(m,btn){
  ['dm0','dm1','dm2'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.hidden=i!==m;});
  document.querySelectorAll('.mode-tab').forEach((b,i)=>b.classList.toggle('active',i===m));
  document.getElementById('dRes').classList.remove('show');
}
function fN(n){return new Intl.NumberFormat('ar-SA',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n);}
function ri(val,lbl){return '<div class="result-item"><div class="val">'+val+'</div><div class="lbl">'+lbl+'</div></div>';}
const lab={final:'السعر النهائي',saved:'المُوفَّر',pct:'نسبة الخصم',eff:'الخصم الفعلي'};
function calcD(m){
  let html='';
  if(m===0){
    const o=+document.getElementById('d0a').value,p=+document.getElementById('d0b').value;
    if(!o||!p)return;
    const s=o*p/100,f=o-s;
    html=ri(fN(f),lab.final)+ri(fN(s),lab.saved)+ri(fN(p)+'%',lab.pct);
  }else if(m===1){
    const o=+document.getElementById('d1a').value,f=+document.getElementById('d1b').value;
    if(!o||!f)return;
    const p=(o-f)/o*100;
    html=ri(fN(p)+'%',lab.pct)+ri(fN(o-f),lab.saved)+ri(fN(f),lab.final);
  }else{
    const o=+document.getElementById('d2a').value,p1=+document.getElementById('d2b').value||0,p2=+document.getElementById('d2c').value||0;
    if(!o)return;
    const a1=o*(1-p1/100),fin=a1*(1-p2/100);
    const eff=(o-fin)/o*100;
    html=ri(fN(fin),lab.final)+ri(fN(eff.toFixed(1))+'%',lab.eff)+ri(fN(o-fin),lab.saved);
  }
  document.getElementById('dGrid').innerHTML=html;
  document.getElementById('dRes').classList.add('show');
}
</script>

</Layout>
