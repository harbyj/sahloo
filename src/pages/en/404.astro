---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  lang="en"
  title="404 – Page Not Found | Sahloo سهلو"
  description="The page you're looking for doesn't exist."
  canonical="https://sahloo.com/en/404"
>
<main id="main">
  <div class="not-found">
    <div class="big">404</div>
    <h1>Oops! Page not found.</h1>
    <p>The page may have been moved or deleted.</p>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <a href="/en/" class="btn btn-primary">Go Home</a>
      <a href="/en/tools/" class="btn btn-secondary">All Tools</a>
    </div>
  </div>
</main>
</Layout>
