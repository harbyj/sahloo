---
import Layout from '../../../layouts/Layout.astro';
---
<Layout
  lang="en"
  title="GPA Calculator | Sahloo سهلو"
  description="Free GPA calculator — supports 4.0, 5.0, and percentage grading scales. Add unlimited courses."
  canonical="https://sahloo.com/en/tools/gpa-calculator/"
>
<main id="main" class="tool-page">
  <div class="tool-hero"><div class="container--n container">
    <nav class="breadcrumb" aria-label="breadcrumb"><a href="#" class="lang-switch">Home</a><span class="bc-sep" aria-hidden="true">›</span><a href="/en/tools/">Tools</a><span class="bc-sep" aria-hidden="true">›</span><span aria-current="page">GPA Calculator</span></nav>
<script type="application/ld+json">{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sahloo.com/en/"}, {"@type": "ListItem", "position": 2, "name": "Tools", "item": "https://sahloo.com/en/tools/"}, {"@type": "ListItem", "position": 3, "name": "GPA Calculator"}]}</script>
    <div class="tool-hero-content">
      <div class="tool-page-icon" aria-hidden="true">🎓</div>
      <h1 class="tool-page-title">GPA Calculator</h1>
      <p class="tool-page-sub">Calculate GPA on 4.0, 5.0, or percentage scale</p>
    </div>
  </div></div>
  <div class="container--n container" style="padding-top:24px;">
    <div class="calc-card">
      <div class="form-group"><label class="form-label" for="gSys">Grading System</label>
        <select class="form-select" id="gSys" onchange="resetGPA()">
          <option value="4">4.0 System (US)</option>
          <option value="5">5.0 System (Gulf)</option>
          <option value="100">Percentage (100)</option>
        </select>
      </div>
      <p class="form-label" style="margin-bottom:8px;">Courses</p>
      <div id="courses"></div>
      <button class="add-row-btn" onclick="addCourse()" style="margin:8px 0 16px;">＋ + Add Course</button>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="calcGPA()">Calculate GPA →</button>
        <button class="btn btn-secondary" onclick="resetGPA()">Clear All</button>
      </div>
      <div class="result-card" id="gRes" aria-live="polite">
        <div class="result-label">Your GPA</div>
        <div class="result-value" id="gVal">—</div>
        <div class="result-sub"  id="gSub"></div>
      </div>
    </div>
    <div class="info-section"><div class="info-card"><h2>🎓 GPA Grading Systems</h2>
<ul><li><strong>4.0 System:</strong> Standard in USA and Canada. A=4.0, B=3.0, C=2.0, D=1.0</li>
<li><strong>5.0 System:</strong> Common in Saudi Arabia and Gulf universities. A+=5.0, A=4.75</li>
<li><strong>Percentage (100):</strong> Used in Egypt, Morocco, Jordan and more. 90–100 = Excellent</li></ul></div>
<div class="info-card"><h2>💡 How to Use</h2>
<ol class="steps-list"><li>Select your university's grading system</li>
<li>Add each course with its grade and credit hours</li>
<li>Click Calculate to see your cumulative GPA</li></ol></div><div class="info-card" itemscope itemtype="https://schema.org/FAQPage"><h2>❓ FAQ</h2><div class="faq-list"><div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa0" itemprop="name">What is the 4.0 GPA scale?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">The 4.0 scale is standard in the US. A=4.0, B=3.0, C=2.0, D=1.0, F=0. An A+ is also 4.0.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa1" itemprop="name">What is a good GPA?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa1" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">On a 4.0 scale: 3.5+ is excellent, 3.0–3.5 is good, 2.5–3.0 is average. Requirements vary by institution.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa2" itemprop="name">How is GPA calculated?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa2" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">GPA = Sum of (Grade Points × Credit Hours) / Total Credit Hours. This calculator uses weighted averaging.</span></div></div>
</div></div>
</div>
  </div>
  <section class="related-section container--n container" aria-label="Related Tools"><div class="section-hd"><h2 class="section-title">Related Tools</h2><a href="/en/tools/" class="see-all">All Tools</a></div><div class="tools-grid"><a href="/en/tools/percentage-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">Percentage Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/age-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">Age Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/zakat-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">Zakat Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/currency-converter/" class="tool-card"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">Currency Converter</div><div class="tool-arrow" aria-hidden="true">→</div></a></div></section>
</main>

<script is:inline>
const G4={"A+": 4, "A": 4, "A-": 3.7, "B+": 3.3, "B": 3, "B-": 2.7, "C+": 2.3, "C": 2, "C-": 1.7, "D+": 1.3, "D": 1, "F": 0},G5={"A+": 5, "A": 4.75, "A-": 4.5, "B+": 4.25, "B": 4, "B-": 3.75, "C+": 3.5, "C": 3, "C-": 2.75, "D+": 2.5, "D": 2, "F": 0};
let cnt=0;
function gradeOpts(sys){
  if(sys==='100')return '<input type="number" inputmode="decimal" class="form-input" name="grade" placeholder="Score (0-100)" min="0" max="100">';
  const g=sys==='4'?G4:G5;
  return '<select class="form-select" name="grade">'+Object.keys(g).map(k=>`<option>${k}</option>`).join('')+'</select>';
}
function addCourse(){
  cnt++;
  const sys=document.getElementById('gSys').value;
  const row=document.createElement('div');
  row.className='course-row'; row.id='cr'+cnt;
  row.innerHTML=gradeOpts(sys)+'<input type="number" inputmode="numeric" class="form-input" name="hrs" placeholder="Hrs" min="1" max="6" value="3"><button class="rm-btn" onclick="this.parentElement.remove()" aria-label="remove">×</button>';
  document.getElementById('courses').appendChild(row);
}
function resetGPA(){document.getElementById('courses').innerHTML='';cnt=0;addCourse();addCourse();document.getElementById('gRes').classList.remove('show');}
function calcGPA(){
  const sys=document.getElementById('gSys').value;
  const rows=document.querySelectorAll('#courses .course-row');
  let pts=0,hrs=0;
  rows.forEach(row=>{
    const g=row.querySelector('[name="grade"]');
    const h=+row.querySelector('[name="hrs"]').value||0;
    let p=sys==='100'?+g.value||0:(sys==='4'?G4[g.value]:G5[g.value])||0;
    pts+=p*h; hrs+=h;
  });
  if(!hrs)return;
  const gpa=pts/hrs;
  const maxG=sys==='100'?100:+sys;
  const pct=gpa/maxG*100;
  const cat=pct>=90?'Excellent 🏆':pct>=80?'Very Good ⭐':pct>=70?'Good ✅':pct>=60?'Pass':'Fail ❌';
  document.getElementById('gVal').textContent=gpa.toFixed(2)+' / '+maxG;
  document.getElementById('gSub').textContent='Grade: '+cat+' | Credit hours: '+hrs;
  document.getElementById('gRes').classList.add('show');
}
resetGPA();
</script>

</Layout>
