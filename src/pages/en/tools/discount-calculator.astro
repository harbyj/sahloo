---
import Layout from '../../../layouts/Layout.astro';
---
<Layout
  lang="en"
  title="Discount Calculator | Sahloo سهلو"
  description="Free discount calculator — find final price after discount, percentage off, or stacked discounts."
  canonical="https://sahloo.com/en/tools/discount-calculator/"
>
<main id="main" class="tool-page">
  <div class="tool-hero">
    <div class="container--n container">
      <nav class="breadcrumb" aria-label="breadcrumb"><a href="#" class="lang-switch">Home</a><span class="bc-sep" aria-hidden="true">›</span><a href="/en/tools/">Tools</a><span class="bc-sep" aria-hidden="true">›</span><span aria-current="page">Discount Calculator</span></nav>
<script type="application/ld+json">{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sahloo.com/en/"}, {"@type": "ListItem", "position": 2, "name": "Tools", "item": "https://sahloo.com/en/tools/"}, {"@type": "ListItem", "position": 3, "name": "Discount Calculator"}]}</script>
      <div class="tool-hero-content">
        <div class="tool-page-icon" aria-hidden="true">🏷️</div>
        <h1 class="tool-page-title">Discount Calculator</h1>
        <p class="tool-page-sub">Find final price after discount and your savings</p>
      </div>
    </div>
  </div>
  <div class="container--n container" style="padding-top:24px;">
    <div class="calc-card">
      <div class="mode-tabs" role="tablist">
        <button class="mode-tab active" role="tab" onclick="setDM(0,this)">Price after discount</button>
        <button class="mode-tab" role="tab" onclick="setDM(1,this)">Find discount %</button>
        <button class="mode-tab" role="tab" onclick="setDM(2,this)">Stacked discounts</button>
      </div>
      <div id="dm0"><div class="form-row">
        <div class="form-group"><label class="form-label" for="d0a">Original price</label><input type="number" inputmode="decimal" class="form-input" id="d0a" placeholder="300"></div>
        <div class="form-group"><label class="form-label" for="d0b">Discount (%)</label><input type="number" inputmode="decimal" class="form-input" id="d0b" placeholder="20"></div>
      </div><button class="btn btn-primary btn-full" onclick="calcD(0)">Calculate →</button></div>
      <div id="dm1" hidden><div class="form-row">
        <div class="form-group"><label class="form-label" for="d1a">Original price</label><input type="number" inputmode="decimal" class="form-input" id="d1a" placeholder="500"></div>
        <div class="form-group"><label class="form-label" for="d1b">Final price</label><input type="number" inputmode="decimal" class="form-input" id="d1b" placeholder="350"></div>
      </div><button class="btn btn-primary btn-full" onclick="calcD(1)">Calculate →</button></div>
      <div id="dm2" hidden>
        <div class="form-group"><label class="form-label" for="d2a">Original price</label><input type="number" inputmode="decimal" class="form-input" id="d2a" placeholder="1000"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label" for="d2b">First discount (%)</label><input type="number" inputmode="decimal" class="form-input" id="d2b" placeholder="20"></div>
          <div class="form-group"><label class="form-label" for="d2c">Second discount (%)</label><input type="number" inputmode="decimal" class="form-input" id="d2c" placeholder="10"></div>
        </div>
        <button class="btn btn-primary btn-full" onclick="calcD(2)">Calculate →</button>
      </div>
      <div class="result-card" id="dRes" aria-live="polite"><div class="result-grid" id="dGrid"></div></div>
    </div>
    <div class="info-section"><div class="info-card"><h2>🏷️ Smart Shopping Guide</h2>
<p>During sales seasons, stores use stacked discounts to create the illusion of bigger savings. Use this calculator to find the true final price before you buy.</p></div>
<div class="info-card"><h2>💡 Types of Discounts</h2>
<ul><li><strong>Flat discount:</strong> A percentage deducted directly from the original price</li>
<li><strong>Stacked discounts:</strong> e.g. "20% off then extra 10%" — this is NOT 30%!</li>
<li><strong>Buy one get one half price:</strong> Effectively 25% off per item</li>
<li><strong>Coupon code:</strong> Usually applied after the listed discount</li></ul></div><div class="info-card" itemscope itemtype="https://schema.org/FAQPage"><h2>❓ FAQ</h2><div class="faq-list"><div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa0" itemprop="name">What is 20% off $150?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">$150 × 0.20 = $30 savings. Final price = $150 − $30 = $120.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa1" itemprop="name">Do stacked discounts add up?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa1" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">No — 20% off then 10% off ≠ 30% off. The second discount applies to the already-discounted price. 20%+10% stacked = 28% effective discount.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa2" itemprop="name">How do I find the original price?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa2" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">If final price = $80 after 20% off, original = $80 / (1−0.20) = $80 / 0.80 = $100.</span></div></div>
</div></div>
</div>
  </div>
  <section class="related-section container--n container" aria-label="Related Tools"><div class="section-hd"><h2 class="section-title">Related Tools</h2><a href="/en/tools/" class="see-all">All Tools</a></div><div class="tools-grid"><a href="/en/tools/percentage-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">Percentage Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/age-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">Age Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/zakat-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">Zakat Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/currency-converter/" class="tool-card"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">Currency Converter</div><div class="tool-arrow" aria-hidden="true">→</div></a></div></section>
</main>

<script is:inline>
function setDM(m,btn){
  ['dm0','dm1','dm2'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.hidden=i!==m;});
  document.querySelectorAll('.mode-tab').forEach((b,i)=>b.classList.toggle('active',i===m));
  document.getElementById('dRes').classList.remove('show');
}
function fN(n){return new Intl.NumberFormat('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n);}
function ri(val,lbl){return '<div class="result-item"><div class="val">'+val+'</div><div class="lbl">'+lbl+'</div></div>';}
const lab={final:'Final Price',saved:'You Save',pct:'Discount %',eff:'Effective Discount'};
function calcD(m){
  let html='';
  if(m===0){
    const o=+document.getElementById('d0a').value,p=+document.getElementById('d0b').value;
    if(!o||!p)return;
    const s=o*p/100,f=o-s;
    html=ri(fN(f),lab.final)+ri(fN(s),lab.saved)+ri(fN(p)+'%',lab.pct);
  }else if(m===1){
    const o=+document.getElementById('d1a').value,f=+document.getElementById('d1b').value;
    if(!o||!f)return;
    const p=(o-f)/o*100;
    html=ri(fN(p)+'%',lab.pct)+ri(fN(o-f),lab.saved)+ri(fN(f),lab.final);
  }else{
    const o=+document.getElementById('d2a').value,p1=+document.getElementById('d2b').value||0,p2=+document.getElementById('d2c').value||0;
    if(!o)return;
    const a1=o*(1-p1/100),fin=a1*(1-p2/100);
    const eff=(o-fin)/o*100;
    html=ri(fN(fin),lab.final)+ri(fN(eff.toFixed(1))+'%',lab.eff)+ri(fN(o-fin),lab.saved);
  }
  document.getElementById('dGrid').innerHTML=html;
  document.getElementById('dRes').classList.add('show');
}
</script>

</Layout>
