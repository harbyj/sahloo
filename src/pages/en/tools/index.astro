---
import Layout from '../../../layouts/Layout.astro';
---
<Layout
  lang="en"
  title="All Tools | Sahloo سهلو"
  description="All free Sahloo tools — percentage calculator, age calculator, currency converter, Zakat calculator, and more useful utilities."
  canonical="https://sahloo.com/en/tools/"
>
<main id="main">
  <div class="tools-index-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/en/">Home</a><span class="bc-sep" aria-hidden="true">›</span>
        <span aria-current="page">All Tools</span>
      </nav>
      <h1 style="margin-top:14px;">All <em>Tools</em></h1>
      <p>Free and no sign-up required</p>
    </div>
  </div>
  <div class="container" style="padding-bottom:60px;">
    <div class="cats-row" style="margin-bottom:20px;">
      <button class="cat-chip active" data-cat="all"><span aria-hidden="true">🔢</span> All</button>
      <button class="cat-chip" data-cat="money"><span aria-hidden="true">💰</span> Finance</button>
      <button class="cat-chip" data-cat="time"><span aria-hidden="true">⏰</span> Time</button>
      <button class="cat-chip" data-cat="study"><span aria-hidden="true">📚</span> Study</button>
      <button class="cat-chip" data-cat="health"><span aria-hidden="true">❤️</span> Health</button>
      <button class="cat-chip" data-cat="quick"><span aria-hidden="true">⚡</span> Quick</button>
    </div>
    <div class="tools-grid">
      <a href="/en/tools/percentage-calculator/" class="tool-card" data-name="percentage calculator" data-kw="calculate percentages — of a number, increase, or decrease" data-cat="quick"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">Percentage Calculator</div><div class="tool-desc">Calculate percentages — of a number, increase, or decrease</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/age-calculator/" class="tool-card" data-name="age calculator" data-kw="find your exact age in years, months, and days" data-cat="time"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">Age Calculator</div><div class="tool-desc">Find your exact age in years, months, and days</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/zakat-calculator/" class="tool-card" data-name="zakat calculator" data-kw="calculate zakat on cash, gold, silver, and investments" data-cat="money"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">Zakat Calculator</div><div class="tool-desc">Calculate Zakat on cash, gold, silver, and investments</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/currency-converter/" class="tool-card" data-name="currency converter" data-kw="live exchange rates — 150+ world currencies" data-cat="money"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">Currency Converter</div><div class="tool-desc">Live exchange rates — 150+ world currencies</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/loan-calculator/" class="tool-card" data-name="loan calculator" data-kw="calculate monthly payment and total interest" data-cat="money"><div class="tool-icon" aria-hidden="true">🏦</div><div class="tool-name">Loan Calculator</div><div class="tool-desc">Calculate monthly payment and total interest</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/date-difference/" class="tool-card" data-name="date difference" data-kw="find the exact difference between two dates" data-cat="time"><div class="tool-icon" aria-hidden="true">📅</div><div class="tool-name">Date Difference</div><div class="tool-desc">Find the exact difference between two dates</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/discount-calculator/" class="tool-card" data-name="discount calculator" data-kw="find final price after discount and your savings" data-cat="money"><div class="tool-icon" aria-hidden="true">🏷️</div><div class="tool-name">Discount Calculator</div><div class="tool-desc">Find final price after discount and your savings</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/bmi-calculator/" class="tool-card" data-name="bmi calculator" data-kw="check if your weight is healthy for your height" data-cat="health"><div class="tool-icon" aria-hidden="true">⚖️</div><div class="tool-name">BMI Calculator</div><div class="tool-desc">Check if your weight is healthy for your height</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/bill-splitter/" class="tool-card" data-name="bill splitter" data-kw="split the bill with friends, including tip" data-cat="quick"><div class="tool-icon" aria-hidden="true">🧾</div><div class="tool-name">Bill Splitter</div><div class="tool-desc">Split the bill with friends, including tip</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/unit-converter/" class="tool-card" data-name="unit converter" data-kw="convert length, weight, temperature, and area" data-cat="quick"><div class="tool-icon" aria-hidden="true">📐</div><div class="tool-name">Unit Converter</div><div class="tool-desc">Convert length, weight, temperature, and area</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/gpa-calculator/" class="tool-card" data-name="gpa calculator" data-kw="calculate gpa on 4.0, 5.0, or percentage scale" data-cat="study"><div class="tool-icon" aria-hidden="true">🎓</div><div class="tool-name">GPA Calculator</div><div class="tool-desc">Calculate GPA on 4.0, 5.0, or percentage scale</div><div class="tool-arrow" aria-hidden="true">→</div></a>
      <a href="/en/tools/days-until/" class="tool-card" data-name="days until" data-kw="count down to any event or date" data-cat="time"><div class="tool-icon" aria-hidden="true">⏳</div><div class="tool-name">Days Until</div><div class="tool-desc">Count down to any event or date</div><div class="tool-arrow" aria-hidden="true">→</div></a>
    </div>
  </div>
</main>
</Layout>
