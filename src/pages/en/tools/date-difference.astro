---
import Layout from '../../../layouts/Layout.astro';
---
<Layout
  lang="en"
  title="Date Difference | Sahloo سهلو"
  description="Free date difference calculator — find exact days, months, and years between any two dates."
  canonical="https://sahloo.com/en/tools/date-difference/"
>
<main id="main" class="tool-page">
  <div class="tool-hero">
    <div class="container--n container">
      <nav class="breadcrumb" aria-label="breadcrumb"><a href="#" class="lang-switch">Home</a><span class="bc-sep" aria-hidden="true">›</span><a href="/en/tools/">Tools</a><span class="bc-sep" aria-hidden="true">›</span><span aria-current="page">Date Difference</span></nav>
<script type="application/ld+json">{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://sahloo.com/en/"}, {"@type": "ListItem", "position": 2, "name": "Tools", "item": "https://sahloo.com/en/tools/"}, {"@type": "ListItem", "position": 3, "name": "Date Difference"}]}</script>
      <div class="tool-hero-content">
        <div class="tool-page-icon" aria-hidden="true">📅</div>
        <h1 class="tool-page-title">Date Difference</h1>
        <p class="tool-page-sub">Find the exact difference between two dates</p>
      </div>
    </div>
  </div>
  <div class="container--n container" style="padding-top:24px;">
    <div class="calc-card">
      <div class="form-row">
        <div class="form-group"><label class="form-label" for="d1">From date</label><input type="date" class="form-input" id="d1"></div>
        <div class="form-group"><label class="form-label" for="d2">To date</label><input type="date" class="form-input" id="d2"></div>
      </div>
      <button class="btn btn-primary btn-full" onclick="calcDD()">Calculate →</button>
      <div class="result-card" id="ddRes" aria-live="polite">
        <div class="result-grid">
          <div class="result-item"><div class="val" id="ddY">0</div><div class="lbl">Year(s)</div></div>
          <div class="result-item"><div class="val" id="ddM">0</div><div class="lbl">Month(s)</div></div>
          <div class="result-item"><div class="val" id="ddD">0</div><div class="lbl">Day(s)</div></div>
        </div>
        <div class="result-sub" id="ddSub"></div>
      </div>
    </div>
    <div class="info-section"><div class="info-card"><h2>📅 When to Use This Tool</h2>
<ul><li>Calculate your years of service in a job</li><li>Find how long until a contract expires</li><li>Calculate a child's exact age for medical records</li><li>Find the duration of a project or training program</li><li>See how long ago an important life event occurred</li></ul></div><div class="info-card" itemscope itemtype="https://schema.org/FAQPage"><h2>❓ FAQ</h2><div class="faq-list"><div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa0" itemprop="name">Does it account for leap years?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">Yes — the calculator accounts for leap years and varying month lengths for maximum accuracy.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa1" itemprop="name">Can I calculate past or future differences?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa1" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">Yes — enter any two dates in any order. The calculator shows the absolute difference.</span></div></div>
<div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"><button class="faq-q" aria-expanded="false" aria-controls="fa2" itemprop="name">What is the maximum date range?<span class="faq-arrow" aria-hidden="true">▼</span></button><div class="faq-a" id="fa2" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">The calculator supports any date range from year 1 AD to far future dates.</span></div></div>
</div></div>
</div>
  </div>
  <section class="related-section container--n container" aria-label="Related Tools"><div class="section-hd"><h2 class="section-title">Related Tools</h2><a href="/en/tools/" class="see-all">All Tools</a></div><div class="tools-grid"><a href="/en/tools/percentage-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">📊</div><div class="tool-name">Percentage Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/age-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🎂</div><div class="tool-name">Age Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/zakat-calculator/" class="tool-card"><div class="tool-icon" aria-hidden="true">🌙</div><div class="tool-name">Zakat Calculator</div><div class="tool-arrow" aria-hidden="true">→</div></a><a href="/en/tools/currency-converter/" class="tool-card"><div class="tool-icon" aria-hidden="true">💱</div><div class="tool-name">Currency Converter</div><div class="tool-arrow" aria-hidden="true">→</div></a></div></section>
</main>

<script is:inline>
document.addEventListener('DOMContentLoaded',()=>document.getElementById('d2').value=new Date().toISOString().split('T')[0]);
function calcDD(){
  const a=new Date(document.getElementById('d1').value),b=new Date(document.getElementById('d2').value);
  if(!document.getElementById('d1').value||!document.getElementById('d2').value)return;
  const[s,e]=a<=b?[a,b]:[b,a];
  let y=e.getFullYear()-s.getFullYear(),m=e.getMonth()-s.getMonth(),d=e.getDate()-s.getDate();
  if(d<0){m--;d+=new Date(e.getFullYear(),e.getMonth(),0).getDate();}
  if(m<0){y--;m+=12;}
  const td=Math.round((e-s)/86400000);
  const fmt=n=>new Intl.NumberFormat('en-US').format(n);
  document.getElementById('ddY').textContent=fmt(y);
  document.getElementById('ddM').textContent=fmt(m);
  document.getElementById('ddD').textContent=fmt(d);
  document.getElementById('ddSub').textContent='Total: '+fmt(td)+' days | '+fmt(Math.floor(td/7))+' weeks';
  document.getElementById('ddRes').classList.add('show');
}
</script>

</Layout>
